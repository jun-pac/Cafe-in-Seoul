# Copy to .env and fill in. Most values are optional for local dev.
PORT=3000
SESSION_SECRET=change-me-to-a-random-string

# Public base URL. Local dev: keep as-is. Behind the Cloudflare tunnel set:
#   BASE_URL=https://seoul-cafe.com
BASE_URL=http://localhost:3000

# --- Google SSO via Identity Services (GIS) ---
# Only the CLIENT ID is needed (public). NO client secret required.
# Create a "Web application" OAuth client at
#   https://console.cloud.google.com/apis/credentials
# and add to "Authorized JavaScript origins":
#   http://localhost:3000   (and later https://seoul-cafe.com)
# If left blank, a "Dev login" (nickname) is used so the app still works.
GOOGLE_CLIENT_ID=

# Comma-separated admin emails. Admins get the Kakao+AI auto-fill tool.
# If empty, EVERY logged-in user is treated as admin (handy for local dev).
ADMIN_EMAILS=

# --- Auto-initialize cafes (admin tool) ---
# Kakao REST API key (Local keyword search + place detail).
#   https://developers.kakao.com  ->  내 애플리케이션  ->  REST API 키
KAKAO_API_KEY=

# OpenAI: used to infer soft fields (floors/size/outlets/view) from reviews.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
